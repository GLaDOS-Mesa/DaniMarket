# Database
DATABASE_URL="postgresql://danimarket:danimarket_dev@localhost:5432/danimarket"

# Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=5242880
MAX_FILES_PER_LISTING=6

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# App
NUXT_PUBLIC_API_BASE="/api"
NUXT_PUBLIC_APP_URL="http://localhost:3000"

# eBay API (Sandbox)
EBAY_CLIENT_ID=your_sandbox_client_id
EBAY_CLIENT_SECRET=your_sandbox_client_secret
EBAY_REDIRECT_URI=your_sandbox_RuName
EBAY_ENV=sandbox
# Production: https://api.ebay.com | Sandbox: https://api.sandbox.ebay.com
EBAY_API_URL=https://api.sandbox.ebay.com
# Production: https://auth.ebay.com | Sandbox: https://auth.sandbox.ebay.com
EBAY_AUTH_URL=https://auth.sandbox.ebay.com
